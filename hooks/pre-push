#!/usr/bin/env bash
set -euo pipefail

echo "=== pre-push ==="

# Validate JSON files are well-formed
echo "Checking JSON syntax..."
for f in config.json manifest.json; do
  if [ -f "$f" ]; then
    if ! python3 -m json.tool "$f" > /dev/null 2>&1; then
      echo "ERROR: $f is not valid JSON"
      exit 1
    fi
    echo "  ✓ $f"
  fi
done

# Basic JS syntax check for all JS files
echo "Checking JS syntax..."
for f in js/*.js tests/*.js; do
  if [ -f "$f" ]; then
    if ! node --check "$f" 2>/dev/null; then
      echo "ERROR: $f has syntax errors"
      exit 1
    fi
    echo "  ✓ $f"
  fi
done

# Placeholder: full test suite will go here once test runner is implemented
# See exec plan: 2026-03-13-testing-and-linting-infrastructure.md

echo "=== pre-push passed ==="
