#!/usr/bin/env bash
set -euo pipefail

echo "=== pre-commit ==="

# Validate JSON files are well-formed
echo "Checking JSON syntax..."
for f in config.json manifest.json; do
  if [ -f "$f" ]; then
    if ! python3 -m json.tool "$f" > /dev/null 2>&1; then
      echo "ERROR: $f is not valid JSON"
      exit 1
    fi
    echo "  ✓ $f"
  fi
done

# Basic JS syntax check (catches gross syntax errors)
echo "Checking JS syntax..."
for f in $(git diff --cached --name-only --diff-filter=ACM -- '*.js'); do
  if [ -f "$f" ]; then
    if ! node --check "$f" 2>/dev/null; then
      echo "ERROR: $f has syntax errors"
      exit 1
    fi
    echo "  ✓ $f"
  fi
done

# Lint (requires node_modules)
if [ -d "node_modules" ]; then
  echo "Running lint..."
  npx eslint js/ tests/ --no-error-on-unmatched-pattern
  echo "  ✓ lint passed"

  echo "Checking formatting..."
  npx prettier --check "**/*.{js,json,md,yml,yaml,css,html}"
  echo "  ✓ format check passed"

  echo "Running unit tests..."
  npx vitest run
  echo "  ✓ unit tests passed"
else
  echo "  ⚠ node_modules not found — skipping lint, format, and tests (run npm install)"
fi

echo "=== pre-commit passed ==="
